# Example environment configuration for nmdc-lakehouse.
# Copy to `.env` and fill in values. Loaded automatically by `just` recipes.

# --- Mongo (NMDC) ---
# For local dev with a restored dump (default):
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DBNAME=nmdc
MONGO_USERNAME=admin
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_REPLICA_SET=
MONGO_DIRECT_CONNECTION=false

# For GCP production via SSH tunnel (see docs/mongodb-connection.md):
# MONGO_PORT=27124
# MONGO_DBNAME=nmdc
# MONGO_USERNAME=<your-mongodb-username>
# MONGO_PASSWORD=<your-mongodb-password>
# MONGO_AUTH_SOURCE=admin
# MONGO_DIRECT_CONNECTION=true

# --- Postgres (optional) ---
POSTGRES_DSN=postgresql://user:pass@localhost:5432/nmdc

# --- Lakehouse output ---
# Local directory or remote URI (e.g. s3://bucket/prefix).
LAKEHOUSE_ROOT=./lakehouse

# --- Test gating ---
# Set to "true" to run tests marked @pytest.mark.integration.
ENABLE_DB_TESTS=false
