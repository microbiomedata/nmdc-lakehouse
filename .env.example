# Example environment configuration for nmdc-lakehouse.
# Copy to `.env` and fill in values. Loaded automatically by `just` recipes.

# --- MongoDB (NMDC) ---
# Decomposed connection settings, matching nmdc-runtime's env-var naming.
# Recipes assemble a mongodb:// URI from these when needed (mongorestore,
# mongosh). Leave username/password blank for local unauthenticated Mongo.
# The default database name (nmdc_lakehouse_prep) avoids colliding with an
# nmdc-runtime dev stack that uses "nmdc" on port 27018.
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DBNAME=nmdc_lakehouse_prep
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_REPLICA_SET=

# Optional: override the assembled URI entirely (useful for Atlas, SSH
# tunnels, or any non-local host). When set, this takes precedence over
# the decomposed fields above.
# MONGO_URI=mongodb://admin:root@localhost:27018/nmdc_lakehouse_prep

# --- NERSC dump retrieval ---
# Used by `just list-dumps` and `just fetch-dump`.
# sshproxy writes a short-lived SSH key (~/.ssh/nersc) and certificate
# (~/.ssh/nersc-cert.pub, 24h lifetime) pair. Refresh both with:
#   sshproxy -u $NERSC_USER
# ssh -i <key-path> automatically loads the adjacent -cert.pub.
NERSC_USER=
# NERSC_SSH_KEY=~/.ssh/nersc
# NERSC_HOST=dtn01.nersc.gov

# Which NERSC dump mirror to use: "prod" (default) or "test". Matches NMDC's
# bucket naming: nmdc-runtime-{prod,test}-mongo-backup.
NMDC_MONGO_SOURCE=prod

# Preferred dump timestamp for `just fetch-dump`. "latest" picks the newest.
# Pin to a specific timestamp for reproducibility, e.g. 20260420_060655.
NMDC_DUMP=latest

# --- Postgres (optional, not yet wired up) ---
POSTGRES_DSN=postgresql://user:pass@localhost:5432/nmdc

# --- Lakehouse output (not yet wired up) ---
# Local directory or remote URI (e.g. s3://bucket/prefix).
LAKEHOUSE_ROOT=./lakehouse

# --- Test gating ---
# Set to "true" to run tests marked @pytest.mark.integration.
ENABLE_DB_TESTS=false
