# Copy this file to local/.env and adjust as needed.
# local/.env is gitignored.

# All recipes and Python code read MONGO_URI. The database name is the path component.
# Examples:
#   mongodb://localhost:27017/nmdc                          (local, no auth)
#   mongodb://admin:root@localhost:27018/nmdc               (nmdc-runtime dev)
#   mongodb://user:pass@myhost:27017/nmdc                   (remote)
MONGO_URI=mongodb://localhost:27017/nmdc
