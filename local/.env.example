# Copy this file to local/.env and adjust as needed.
# local/.env is gitignored.

# ---------- MongoDB connection ----------
# Target database for restore, drop, and queries. The dump's internal namespace
# is "nmdc"; we restore into a dedicated db by default so an existing "nmdc"
# database (e.g. from nmdc-runtime dev) stays untouched. MONGO_DBNAME matches
# nmdc-runtime's env-var convention.
MONGO_DBNAME=nmdc_lakehouse_prep

# MONGO_URI defaults to mongodb://localhost:27017/$MONGO_DBNAME. Override to
# use auth, a non-standard port, or a remote host. Examples:
#   mongodb://localhost:27017/nmdc_lakehouse_prep            (local, no auth)
#   mongodb://admin:root@localhost:27018/nmdc_lakehouse_prep (nmdc-runtime dev)
#   mongodb://user:pass@myhost:27017/nmdc_lakehouse_prep     (remote)
# MONGO_URI=mongodb://localhost:27017/nmdc_lakehouse_prep

# ---------- NERSC dump retrieval ----------
# Used by `just list-dumps` and `just fetch-dump`. Refresh the SSH cert
# (24h lifetime) with: sshproxy -u $NERSC_USER
NERSC_USER=
# NERSC_SSH_KEY=~/.ssh/nersc
# NERSC_HOST=dtn01.nersc.gov

# Which NERSC dump mirror to use: "prod" (default) or "test". Matches NMDC's
# bucket naming: nmdc-runtime-{prod,test}-mongo-backup.
NMDC_MONGO_SOURCE=prod

# Preferred dump timestamp for `just fetch-dump`. "latest" picks the newest.
# Pin to a specific timestamp for reproducibility, e.g. 20260420_060655.
NMDC_DUMP=latest
